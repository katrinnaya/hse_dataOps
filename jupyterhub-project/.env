# JupyterHub configuration
JUPYTERHUB_HOST=0.0.0.0
JUPYTERHUB_PORT=8000
JUPYTERHUB_ADMIN=admin
JUPYTERHUB_ADMIN_PASSWORD=admin_password
JUPYTERHUB_COOKIE_SECRET=your-cookie-secret-here-change-me
JUPYTERHUB_PROXY_AUTH_TOKEN=your-proxy-auth-token-change-me

# Container name
JUPYTERHUB_CONTAINER_NAME=jupyterhub-server
